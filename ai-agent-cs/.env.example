# ==========================================================
# AI-AGENT-CS - Apollo Hotel RAG AI Agent
# ==========================================================

# ==========================================================
# GEMINI CLOUD CONFIGURATION
# ==========================================================
# Provide your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Provide a fallback API key that will be used if the first key fails
GEMINI_API_KEY_FALLBACK=your_gemini_api_key_fallback_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ==========================================================
# RAG SETTINGS
# ==========================================================
# Number of chunks retrieved per query
TOP_K=4
# Minimum similarity score (optional threshold)
SIMILARITY_THRESHOLD=0.30
# Escalation confidence threshold
CONFIDENCE_THRESHOLD=0.75
# Maximum tokens per LLM response
MAX_OUTPUT_TOKENS=512

# ==========================================================
# CHUNKING SETTINGS
# ==========================================================
# Token size per chunk
CHUNK_SIZE=500
# Overlap between chunks
CHUNK_OVERLAP=80

# ==========================================================
# VECTOR STORE SETTINGS
# ==========================================================
# Vector store directory
VECTOR_STORE_PATH=data/vector_store/
# FAISS index filename
FAISS_INDEX_FILE=faiss_index.index
# Metadata storage file
METADATA_FILE=metadata.json

# ==========================================================
# APPLICATION SETTINGS
# ==========================================================
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Single-Container Deployment (e.g., Koyeb, Fly.io, Railway)
# For hosted environments, both the Frontend and API run on the exact same URL.
API_BASE_URL=https://your-ngrok-url.ngrok-free.app
FRONTEND_URL=${API_BASE_URL}/frontend

# ==========================================================
# REDIS CONTEXT MEMORY
# ==========================================================
# Use "localhost" for local dev, "redis" for Docker Compose
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================================
# AI PROVIDER SETTINGS
# ==========================================================
# Provider: "gemini" or "ollama"
LLM_PROVIDER=gemini

# Ollama Config (Only if LLM_PROVIDER=ollama)
# Use "http://localhost:11434" for local Windows dev
# Use "http://host.docker.internal:11434" for Docker (host-running Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# ==========================================================
# GOOGLE SHEETS INTEGRATION
# ==========================================================
CUSTOMER_SHEET_ID=your_customer_sheet_id
FOOD_SHEET_ID=your_food_sheet_id
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycb.../exec
BACKEND_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/webhook/sheets-edit

# ==========================================================
# EMPLOYEE NOTIFICATION BOTS (Specialized Staff Bots)
# ==========================================================
NOTIFY_BOOKING_TOKEN=your_booking_bot_token
NOTIFY_BOOKING_CHAT_ID=your_staff_group_chat_id

NOTIFY_FOOD_TOKEN=your_food_bot_token
NOTIFY_FOOD_CHAT_ID=your_staff_group_chat_id

NOTIFY_REQUEST_TOKEN=your_request_bot_token
NOTIFY_REQUEST_CHAT_ID=your_staff_group_chat_id

# ==========================================================
# OPTIONAL / FUTURE SETTINGS
# ==========================================================
# Rate limiting (requests per minute)
RATE_LIMIT=60
# Enable escalation logging
ENABLE_ESCALATION_LOG=True
# Ticket storage path
TICKET_STORAGE_PATH=data/tickets/
