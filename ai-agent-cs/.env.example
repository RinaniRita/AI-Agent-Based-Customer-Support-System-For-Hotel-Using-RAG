# ==========================================================
# AI-AGENT-CS - Apollo Hotel RAG AI Agent
# ==========================================================

# ==========================================================
# OLLAMA CONFIGURATION
# ==========================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Chat model (use the model you downloaded, e.g., qwen2.5:7b-instruct)
OLLAMA_MODEL=qwen2.5:7b-instruct

# Embedding model (if using Ollama for embeddings, otherwise keep separate)
OLLAMA_EMBEDDING_MODEL=all-MiniLM-L6-v2


# ==========================================================
# RAG SETTINGS
# ==========================================================

# Number of chunks retrieved per query
TOP_K=4

# Minimum similarity score (optional threshold)
SIMILARITY_THRESHOLD=0.30

# Escalation confidence threshold
CONFIDENCE_THRESHOLD=0.75

# Maximum tokens per LLM response
MAX_OUTPUT_TOKENS=512


# ==========================================================
# CHUNKING SETTINGS
# ==========================================================

# Token size per chunk
CHUNK_SIZE=500

# Overlap between chunks
CHUNK_OVERLAP=80


# ==========================================================
# VECTOR STORE SETTINGS
# ==========================================================

# Vector store directory
VECTOR_STORE_PATH=data/vector_store/

# FAISS index filename
FAISS_INDEX_FILE=faiss_index.index

# Metadata storage file
METADATA_FILE=metadata.json


# ==========================================================
# APPLICATION SETTINGS
# ==========================================================

APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Frontend URL (GitHub Pages)
FRONTEND_URL=https://your-username.github.io/repo/path
 
# Backend URL (For static HTML fetch requests, e.g. Ngrok)
API_BASE_URL=https://7d41-42-118-12-116.ngrok-free.app

# ==========================================================
# OPTIONAL (Future Production Use)
# ==========================================================

# Rate limiting (requests per minute)
RATE_LIMIT=60

# Enable escalation logging
ENABLE_ESCALATION_LOG=True

# Ticket storage path
TICKET_STORAGE_PATH=data/tickets/

# ==========================================================
# GOOGLE SHEETS INTEGRATION
# ==========================================================
CUSTOMER_SHEET_ID=your_customer_sheet_id
FOOD_SHEET_ID=your_food_sheet_id
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
BACKEND_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/webhook/sheets-edit
