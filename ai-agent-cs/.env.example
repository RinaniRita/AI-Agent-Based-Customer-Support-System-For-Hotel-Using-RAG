# ==========================================================
# AI-AGENT-CS - Apollo Hotel RAG AI Agent
# ==========================================================

# ==========================================================
# GEMINI CLOUD CONFIGURATION
# ==========================================================

# Provide your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Provide a fallback API key that will be used if the first key fails
GEMINI_API_KEY_FALLBACK=your_gemini_api_key_fallback_here
GEMINI_MODEL=gemini-2.5-flash-lite


# ==========================================================
# RAG SETTINGS
# ==========================================================

# Number of chunks retrieved per query
TOP_K=4

# Minimum similarity score (optional threshold)
SIMILARITY_THRESHOLD=0.30

# Escalation confidence threshold
CONFIDENCE_THRESHOLD=0.75

# Maximum tokens per LLM response
MAX_OUTPUT_TOKENS=512


# ==========================================================
# CHUNKING SETTINGS
# ==========================================================

# Token size per chunk
CHUNK_SIZE=500

# Overlap between chunks
CHUNK_OVERLAP=80


# ==========================================================
# VECTOR STORE SETTINGS
# ==========================================================

# Vector store directory
VECTOR_STORE_PATH=data/vector_store/

# FAISS index filename
FAISS_INDEX_FILE=faiss_index.index

# Metadata storage file
METADATA_FILE=metadata.json


# ==========================================================
# APPLICATION SETTINGS
# ==========================================================

APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Single-Container Deployment (e.g., Koyeb, Fly.io, Railway)
# For hosted environments, both the Frontend and API run on the exact same URL.
# Example: If your Koyeb app is https://my-hotel.koyeb.app
API_BASE_URL=https://your-app-url.com
FRONTEND_URL=${API_BASE_URL}/frontend

# ==========================================================
# OPTIONAL (Future Production Use)
# ==========================================================

# Rate limiting (requests per minute)
RATE_LIMIT=60

# Enable escalation logging
ENABLE_ESCALATION_LOG=True

# Ticket storage path
TICKET_STORAGE_PATH=data/tickets/

# ==========================================================
# GOOGLE SHEETS INTEGRATION
# ==========================================================
CUSTOMER_SHEET_ID=your_customer_sheet_id
FOOD_SHEET_ID=your_food_sheet_id
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
BACKEND_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/webhook/sheets-edit
